# .env.example

# Brevo (formerly Sendinblue) configuration
BREVO_API_KEY=your_brevo_api_key_here

# Stripe configuration
STRIPE_API_KEY=your_stripe_api_key
NEXT_PUBLIC_STRIPE_PRICE_BASIQUE=price_xxxxxxxxxxxxxxxxxx
NEXT_PUBLIC_STRIPE_PRICE_ILLIMITE=price_xxxxxxxxxxxxxxxxxx

# Stripe Webhook
STRIPE_WEBHOOK_SECRET=whsec_xxxxxxxxxxxxxxxxxx

# Supabase configuration
NEXT_PUBLIC_SUPABASE_URL=your_supabase_url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key

# Supabase service role (pour usage serveur uniquement, ne jamais exposer côté client)
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

BACKEND_URL=https://eloquence-api-production.up.railway.app

# API URL for the juridical chat (client-side, must be NEXT_PUBLIC_)
NEXT_PUBLIC_API_URL=http://localhost:8000

# Groq API key (used for audio transcription via Whisper and AI jury behavior)
GROQ_API_KEY=your_groq_api_key

# JWT secret key (used to sign email confirmation tokens — keep secret, never expose client-side)
JWT_SECRET=your_jwt_secret_key_here

# Public app URL (used to build confirmation links in emails)
NEXT_PUBLIC_SITE_URL=https://www.éloquence.fr
